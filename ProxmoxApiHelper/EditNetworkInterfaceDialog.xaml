<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.EditNetworkInterfaceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:helpers="using:ProxmoxApiHelper.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit Network Interface">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{ThemeResource AccentButtonBackground}">
                    <FontIcon Glyph="&#xE839;" FontSize="18"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Edit Network Interface"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Configure network adapter settings"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20">
            <StackPanel Spacing="12">

                <!-- Basic Configuration Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE839;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Basic Configuration"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TypeComboBox"
                                      Header="Interface Type"
                                      PlaceholderText="Select type"
                                      SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Bridge"/>
                                <ComboBoxItem Content="Bond"/>
                                <ComboBoxItem Content="Eth"/>
                                <ComboBoxItem Content="VLAN"/>
                            </ComboBox>
                            <ComboBox x:Name="MethodComboBox"
                                      Grid.Column="1"
                                      Header="Configuration Method"
                                      PlaceholderText="Select method"
                                      SelectedItem="{Binding SelectedMethod, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Static"/>
                                <ComboBoxItem Content="DHCP"/>
                                <ComboBoxItem Content="Manual"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- IP Configuration Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE968;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="IP Configuration"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Address, Mode=TwoWay}"
                                     Header="IP Address"
                                     PlaceholderText="192.168.1.100"
                                     HorizontalAlignment="Stretch"/>
                            <TextBox Text="{Binding Netmask, Mode=TwoWay}"
                                     Grid.Column="1"
                                     Header="Subnet Mask / Prefix"
                                     PlaceholderText="24 or 255.255.255.0"
                                     HorizontalAlignment="Stretch"/>
                        </Grid>
                        <TextBox Text="{Binding Gateway, Mode=TwoWay}"
                                 Header="Default Gateway"
                                 PlaceholderText="192.168.1.1"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Bridge Configuration Card (conditional) -->
                <Border x:Name="BridgeConfigPanel"
                        Visibility="{Binding IsBridgeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xF0B2;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Bridge Configuration"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBox Text="{Binding BridgePorts, Mode=TwoWay}"
                                 Header="Bridge Ports"
                                 PlaceholderText="Space-separated port list (e.g. eth0 eth1)"
                                 HorizontalAlignment="Stretch"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox SelectedItem="{Binding SelectedBridgeStp, Mode=TwoWay}"
                                      Header="STP Mode"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="On"/>
                                <ComboBoxItem Content="Off"/>
                            </ComboBox>
                            <TextBox Text="{Binding BridgeFd, Mode=TwoWay}"
                                     Grid.Column="1"
                                     Header="Forward Delay (ms)"
                                     PlaceholderText="0"
                                     HorizontalAlignment="Stretch"/>
                        </Grid>
                        <CheckBox IsChecked="{Binding IsBridgeVlanAware, Mode=TwoWay}"
                                  Content="VLAN Aware bridge"/>
                    </StackPanel>
                </Border>

                <!-- Additional Settings Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Additional Settings"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <CheckBox IsChecked="{Binding IsAutostart, Mode=TwoWay}"
                                  Content="Enable Autostart on boot"/>
                        <TextBox Text="{Binding Comments, Mode=TwoWay}"
                                 Header="Comments"
                                 PlaceholderText="Notes about this interface"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer actions -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Command="{Binding CancelCommand}" MinWidth="80"/>
                <Button Content="Save Changes"
                        Command="{Binding SaveCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        MinWidth="120"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
