<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.AddPoolWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Create Resource Pool">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Border MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="32,28">
            <StackPanel Spacing="0">

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{ThemeResource AccentButtonBackground}">
                        <FontIcon Glyph="&#xE8B8;" FontSize="20"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Create Resource Pool"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Add a new pool to organize resources"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Opacity="0.6"/>
                    </StackPanel>
                </StackPanel>

                <!-- Pool ID -->
                <TextBox x:Name="PoolIdTextBox"
                         Header="Pool ID"
                         PlaceholderText="Enter pool identifier"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,12"/>

                <!-- Comment -->
                <TextBox x:Name="CommentTextBox"
                         Header="Comment (optional)"
                         PlaceholderText="Add a description for this pool"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         HorizontalAlignment="Stretch"
                         Margin="0,0,0,24"/>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="Cancel" Click="CancelButton_Click" Width="80"/>
                    <Button Content="Create Pool"
                            Click="CreatePoolButton_Click"
                            Style="{ThemeResource AccentButtonStyle}"
                            MinWidth="110"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
