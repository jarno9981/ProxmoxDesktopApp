<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.EditUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit User">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
            <Border Width="40" Height="40" CornerRadius="10"
                    Background="{ThemeResource AccentButtonBackground}">
                <FontIcon Glyph="&#xE77B;" FontSize="20"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Edit User"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Modify user account settings"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.6"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Identity Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77B;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Identity"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="UserIdTextBox"
                                 Header="User ID"
                                 IsReadOnly="True"
                                 HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="FirstNameTextBox"
                                 Header="First Name"
                                 PlaceholderText="First name"
                                 HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="LastNameTextBox"
                                 Header="Last Name"
                                 PlaceholderText="Last name"
                                 HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="EmailTextBox"
                                 Header="Email Address"
                                 PlaceholderText="user@example.com"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Credentials Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Credentials"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <PasswordBox x:Name="PasswordBox"
                                     Header="New Password"
                                     PlaceholderText="Leave blank to keep current password"
                                     HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Account Settings Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Account Settings"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <CheckBox x:Name="EnabledCheckBox" Content="Account Enabled"/>
                        <DatePicker x:Name="ExpiryDatePicker"
                                    Header="Expiry Date"
                                    HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="CommentTextBox"
                                 Header="Comment"
                                 PlaceholderText="Notes about this account"
                                 HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="KeysTextBox"
                                 Header="Two-Factor Auth Keys"
                                 PlaceholderText="YubiKey or TOTP keys"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Groups Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE902;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Group Membership"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ListView x:Name="GroupsListView"
                                  MaxHeight="160"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding GroupId}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,2"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Tokens Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AC;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="API Tokens"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ListView x:Name="TokensListView"
                                  MaxHeight="120"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Options Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <CheckBox x:Name="AppendCheckBox"
                              Content="Append values instead of replacing existing ones"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,16,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80"/>
            <Button Content="Save Changes"
                    Click="SaveButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    MinWidth="120"/>
        </StackPanel>
    </Grid>
</Window>
