<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.CreateUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Create New User">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{ThemeResource AccentButtonBackground}">
                    <FontIcon Glyph="&#xE77B;" FontSize="18"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Create New User"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Add a Proxmox user account"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollMode="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20">
            <StackPanel Spacing="12">

                <!-- Error InfoBar -->
                <InfoBar x:Name="ErrorInfoBar"
                         IsOpen="False"
                         Severity="Error"
                         Title="Error"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="True"/>

                <!-- Required Information Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Required Information"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="UserIdTextBox"
                                 Header="User ID"
                                 PlaceholderText="username@pve"
                                 HorizontalAlignment="Stretch"
                                 Text="{x:Bind ViewModel.UserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Header="Password"
                                     PlaceholderText="Enter a secure password"
                                     HorizontalAlignment="Stretch"
                                     Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Personal Information Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77B;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Personal Information"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FirstNameTextBox"
                                     Header="First Name"
                                     PlaceholderText="First name"
                                     HorizontalAlignment="Stretch"
                                     Text="{x:Bind ViewModel.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox x:Name="LastNameTextBox"
                                     Grid.Column="1"
                                     Header="Last Name"
                                     PlaceholderText="Last name"
                                     HorizontalAlignment="Stretch"
                                     Text="{x:Bind ViewModel.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBox x:Name="EmailTextBox"
                                 Header="Email Address"
                                 PlaceholderText="user@example.com"
                                 HorizontalAlignment="Stretch"
                                 Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Account Settings Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Account Settings"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="EnableToggle"
                                      Header="Account Status"
                                      OnContent="Enabled"
                                      OffContent="Disabled"
                                      IsOn="{x:Bind ViewModel.IsEnabled, Mode=TwoWay}"/>
                        <CalendarDatePicker x:Name="ExpiryDatePicker"
                                            Header="Account Expiry Date"
                                            PlaceholderText="No expiry"
                                            HorizontalAlignment="Stretch"
                                            Date="{x:Bind ViewModel.ExpiryDate, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <!-- Group Membership Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE902;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Group Membership"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ComboBox x:Name="GroupComboBox"
                                  PlaceholderText="Select a group (optional)"
                                  ItemsSource="{x:Bind ViewModel.AvailableGroups, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Additional Settings Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE90F;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Additional Settings"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBox x:Name="CommentTextBox"
                                 Header="Comment"
                                 PlaceholderText="Notes about this user"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 HorizontalAlignment="Stretch"
                                 Text="{x:Bind ViewModel.Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox x:Name="KeysTextBox"
                                 Header="Two-Factor Auth Keys (YubiKey)"
                                 PlaceholderText="Enter authentication keys"
                                 HorizontalAlignment="Stretch"
                                 Text="{x:Bind ViewModel.Keys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer actions -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        MinWidth="80"/>
                <Button x:Name="CreateButton"
                        Content="Create User"
                        Click="CreateButton_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        MinWidth="120"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
