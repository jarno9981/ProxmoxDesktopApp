<Window
    x:Class="ProxmoxApiHelper.WindowProxmox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:ProxmoxApiHelper.Helpers"
    mc:Ignorable="d"
    Title="VM Control Center — Proxmox Dashboard">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <local:StatusToColorConverterProxmox x:Key="StatusToColorConverterProxmox"/>
        </Grid.Resources>

        <NavigationView x:Name="NavViewProxmox"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        OpenPaneLength="220"
                        SelectionChanged="NavViewProxmox_SelectionChanged">

            <NavigationView.Header>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                    <Border Width="28" Height="28" CornerRadius="6"
                            Background="{ThemeResource AccentButtonBackground}">
                        <FontIcon Glyph="&#xE7EF;" FontSize="14"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Proxmox"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Create VM" Tag="create_vm">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F8;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Create LXC" Tag="create_lxc">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F0;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Network Config" Tag="network_config">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE839;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Users &amp; Groups" Tag="grps_config">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Server Stats" Tag="server_stats">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Manage Pools" Tag="manage_pools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA8A;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Snapshots" Tag="snapshots">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Backup" Tag="backup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8AD;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Tasks" Tag="tasks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D5;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Firewall" Tag="firewall">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B6;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Node Mgmt" Tag="node_mgmt">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid>

                <!-- ═══════════════════════════════════════════════════════ DASHBOARD -->
                <Grid x:Name="DashboardContentProxmox" Visibility="Visible" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="VM Dashboard"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <ProgressRing x:Name="LoadingIndicatorProxmox" IsActive="False" Width="20" Height="20"/>
                            <Button x:Name="RefreshButtonProxmox" Click="RefreshButtonProxmox_Click"
                                    ToolTipService.ToolTip="Refresh VM list">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Main content: VM list + detail pane -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" MinWidth="220"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- VM List -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ListView x:Name="VmListViewProxmox"
                                      SelectionChanged="VmListViewProxmox_SelectionChanged"
                                      IsItemClickEnabled="True"
                                      ItemClick="VmListViewProxmox_ItemClick"
                                      Padding="4">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status dot -->
                                            <Ellipse Width="8" Height="8"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding Status, Converter={StaticResource StatusToColorConverterProxmox}}"/>

                                            <!-- Name + node -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{ThemeResource BodyTextBlockStyle}"
                                                           FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Node}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Opacity="0.55"/>
                                                    <TextBlock Text="·"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Opacity="0.35"/>
                                                    <TextBlock Text="{Binding Id}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               Opacity="0.45"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Type badge -->
                                            <Border Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="4"
                                                    Padding="5,2"
                                                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                                <TextBlock Text="{Binding Type}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           FontSize="10"
                                                           Opacity="0.7"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!-- Detail Pane -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Section label -->
                            <TextBlock Grid.Row="0"
                                       Text="VM Details"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,10"/>

                            <!-- Details card -->
                            <Border Grid.Row="1"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <TextBlock x:Name="VmDetailsTextBlockProxmox"
                                           Text="Select a VM or container to view details"
                                           TextWrapping="Wrap"
                                           Opacity="0.6"
                                           Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Border>

                            <!-- Action buttons -->
                            <Border Grid.Row="2"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="StartButtonProxmox" Click="StartButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE768;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                                <TextBlock Text="Start"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="StopButtonProxmox" Click="StopButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE71A;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Stop"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ShutdownButtonProxmox" Click="ShutdownButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7E8;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Shutdown"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ResetButtonProxmox" Click="ResetButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Reset"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="EditButtonProxmox" Click="EditButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Edit"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="SuspendButtonProxmox" Click="SuspendButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE769;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Suspend"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ResumeButtonProxmox" Click="ResumeButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE768;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="Resume"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="CloneButtonProxmox" Click="CloneButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Clone"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="MigrateButtonProxmox" Click="MigrateButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72D;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Migrate"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="ConsoleViewerProxmox"
                                                Visibility="Collapsed"
                                                IsEnabled="False"
                                                Click="ConsoleViewerProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE756;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Console"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="DeleteButtonProxmox" Click="DeleteButtonProxmox_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Delete"
                                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Status InfoBar -->
                    <InfoBar x:Name="StatusInfoBarProxmox"
                             IsOpen="False"
                             Severity="Informational"
                             IsClosable="True"
                             Grid.Row="2"
                             Margin="0,12,0,0"/>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ CREATE VM -->
                <Grid x:Name="CreateVmPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE7F8;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Create New VM" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Configure and provision a new virtual machine" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">

                            <!-- Basic Info Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Basic Information" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewVmIdTextBoxProxmox" Header="VM ID" PlaceholderText="Auto-assigned" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="NewVmNameTextBoxProxmox" Grid.Column="1" Header="VM Name *" PlaceholderText="my-vm" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="NodeSelectionComboBoxProxmox" Header="Node *" PlaceholderText="Select node"
                                                  SelectionChanged="NodeSelectionComboBoxProxmox_SelectionChanged"
                                                  HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="StorageSelectionComboBoxProxmox" Grid.Column="1" Header="Storage *" PlaceholderText="Select storage" HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="PoolSelectionComboBoxProxmox" Grid.Column="2" Header="Pool" PlaceholderText="None (optional)" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <TextBox x:Name="VmDescriptionTextBoxProxmox" Header="Description" PlaceholderText="Optional description" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- System Resources Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7F8;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="System Resources" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="NewVmCpuTextBoxProxmox" Header="CPU Cores *" Value="2" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                        <NumberBox x:Name="NewVmMemoryTextBoxProxmox" Grid.Column="1" Header="Memory (MB) *" Value="2048" Minimum="512" SpinButtonPlacementMode="Compact"/>
                                        <NumberBox x:Name="NewVmDiskTextBoxProxmox" Grid.Column="2" Header="Disk Size (GB) *" Value="20" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="DriveTypeComboBoxProxmox" Header="Boot Disk Type" PlaceholderText="scsi0" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="scsi0"/>
                                            <ComboBoxItem Content="virtio0"/>
                                            <ComboBoxItem Content="sata0"/>
                                            <ComboBoxItem Content="ide0"/>
                                        </ComboBox>
                                        <NumberBox x:Name="NewVmCpuWeightTextBoxProxmox" Grid.Column="1" Header="CPU Weight" Value="1000" Minimum="1" Maximum="10000" SpinButtonPlacementMode="Compact"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Operating System Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7E8;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Operating System" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="OsTypeComboBoxProxmox" Header="OS Type *" PlaceholderText="Select OS type"
                                                  SelectionChanged="OsTypeComboBoxProxmox_SelectionChanged"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Windows"/>
                                            <ComboBoxItem Content="Linux"/>
                                            <ComboBoxItem Content="Other"/>
                                        </ComboBox>
                                        <ComboBox x:Name="OsType" Grid.Column="1" Header="OS Version *" PlaceholderText="Select version" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <ComboBox x:Name="IsoSelectionComboBoxProxmox" Header="ISO Image" PlaceholderText="Select ISO for installation (optional)" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- Network Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE839;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Network Configuration" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CreateVmNetworkModelComboBoxProxmox" Header="Network Model *" PlaceholderText="Select model" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="VirtIO"/>
                                            <ComboBoxItem Content="E1000"/>
                                            <ComboBoxItem Content="RTL8139"/>
                                        </ComboBox>
                                        <TextBox x:Name="CreateVmBridgeTextBoxProxmox" Grid.Column="1" Header="Bridge *" PlaceholderText="vmbr0" Text="vmbr0" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="CreateVmVlanTagTextBoxProxmox" Grid.Column="2" Header="VLAN Tag" PlaceholderText="None" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <CheckBox x:Name="CreateVmFirewallCheckBoxProxmox" Content="Enable Firewall" IsChecked="True"/>
                                </StackPanel>
                            </Border>

                            <!-- Advanced Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE90F;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Advanced Options" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="8">
                                            <CheckBox x:Name="UefiCheckBoxProxmox" Content="Use UEFI"/>
                                            <CheckBox x:Name="OnBootCheckBoxProxmox" Content="Start on boot"/>
                                            <CheckBox x:Name="AgentCheckBoxProxmox" Content="QEMU Guest Agent" IsChecked="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <CheckBox x:Name="AutoStartCheckBoxProxmox" Content="Auto start"/>
                                            <CheckBox x:Name="ProtectionCheckBoxProxmox" Content="Enable protection"/>
                                            <CheckBox x:Name="KvmCheckBoxProxmox" Content="Enable KVM" IsChecked="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="8">
                                            <TextBox x:Name="TagsTextBoxProxmox" Header="Tags" PlaceholderText="tag1,tag2" HorizontalAlignment="Stretch"/>
                                            <TextBox x:Name="StartupOrderTextBoxProxmox" Header="Startup order" PlaceholderText="1" HorizontalAlignment="Stretch"/>
                                            <TextBox x:Name="SshKeysTextBoxProxmox" Header="SSH Keys" PlaceholderText="Public key" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,20">
                                <Button x:Name="CreateVmButtonProxmox"
                                        Content="Create VM"
                                        Click="CreateVmButtonProxmox_Click"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        MinWidth="120"/>
                                <Button x:Name="MassCreateVmButtonProxmox"
                                        Click="MassCreateVmButtonProxmox_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71D;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                        <TextBlock Text="Mass Create VMs"/>
                                    </StackPanel>
                                </Button>
                                <ProgressRing x:Name="CreateVmProgressRing" IsActive="False" Width="20" Height="20"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Mass VM Creation dialog -->
                <ContentDialog x:Name="MassVmCreationDialog"
                               Title="Mass VM Creation"
                               PrimaryButtonText="Create VMs"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="MassVmCreationDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <Grid MinWidth="480">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Pivot Grid.Row="1">
                                <PivotItem Header="Basic Info">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <NumberBox x:Name="MassVmCountNumberBox" Header="Number of VMs *" Value="5" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact"/>
                                            <ComboBox x:Name="MassVmNodeSelectionComboBox" Header="Node *" PlaceholderText="Select node" SelectionChanged="MassVmNodeSelectionComboBox_SelectionChanged" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassVmStorageSelectionComboBox" Header="Storage *" PlaceholderText="Select storage" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassVmPoolSelectionComboBox" Header="Pool" PlaceholderText="None (optional)" HorizontalAlignment="Stretch"/>
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <NumberBox x:Name="MassVmCpuCoresNumberBox" Header="CPU Cores *" Value="1" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                                <NumberBox x:Name="MassVmMemoryMBNumberBox" Grid.Column="1" Header="Memory (MB) *" Value="1024" Minimum="512" SpinButtonPlacementMode="Compact"/>
                                                <NumberBox x:Name="MassVmDiskSizeGBNumberBox" Grid.Column="2" Header="Disk (GB) *" Value="20" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </PivotItem>
                                <PivotItem Header="OS &amp; Network">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <ComboBox x:Name="MassVmOsComboBox" Header="OS" PlaceholderText="Select OS" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Windows"/>
                                                <ComboBoxItem Content="Linux"/>
                                                <ComboBoxItem Content="Other"/>
                                            </ComboBox>
                                            <ComboBox x:Name="MassVmOsTypeComboBox" Header="OS Type *" PlaceholderText="Select OS type" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="l26"/>
                                                <ComboBoxItem Content="l24"/>
                                                <ComboBoxItem Content="win11"/>
                                                <ComboBoxItem Content="win10"/>
                                                <ComboBoxItem Content="win8"/>
                                                <ComboBoxItem Content="win7"/>
                                                <ComboBoxItem Content="other"/>
                                            </ComboBox>
                                            <ComboBox x:Name="MassVmIsoSelectionComboBox" Header="ISO Image" PlaceholderText="Select ISO (optional)" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassVmDiskTypeComboBox" Header="Boot Disk" PlaceholderText="Select type" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="scsi0"/>
                                                <ComboBoxItem Content="virtio0"/>
                                                <ComboBoxItem Content="sata0"/>
                                                <ComboBoxItem Content="ide0"/>
                                            </ComboBox>
                                            <ComboBox x:Name="MassVmNetworkModelComboBox" Header="Network Model *" PlaceholderText="Select model" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="VirtIO"/>
                                                <ComboBoxItem Content="E1000"/>
                                                <ComboBoxItem Content="RTL8139"/>
                                            </ComboBox>
                                            <TextBox x:Name="MassVmBridgeTextBox" Header="Bridge *" PlaceholderText="vmbr0" Text="vmbr0" HorizontalAlignment="Stretch"/>
                                            <CheckBox x:Name="MassVmFirewallCheckBox" Content="Enable Firewall" IsChecked="True"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </PivotItem>
                                <PivotItem Header="Advanced">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <CheckBox x:Name="MassVmUefiCheckBox" Content="Use UEFI"/>
                                            <CheckBox x:Name="MassVmOnBootCheckBox" Content="Start on boot" IsChecked="True"/>
                                            <CheckBox x:Name="MassVmAgentCheckBox" Content="QEMU Guest Agent" IsChecked="True"/>
                                            <CheckBox x:Name="MassVmKvmCheckBox" Content="Enable KVM" IsChecked="True"/>
                                            <CheckBox x:Name="MassVmProtectionCheckBox" Content="Enable Protection"/>
                                            <TextBox x:Name="MassVmTagsTextBox" Header="Tags" PlaceholderText="tag1,tag2" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </PivotItem>
                            </Pivot>
                            <ProgressBar Grid.Row="2" x:Name="MassVmCreationProgressBar" Visibility="Collapsed" Margin="0,12,0,0"/>
                        </Grid>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- ═══════════════════════════════════════════════════════ CREATE LXC -->
                <Grid x:Name="CreateLxcPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE7F0;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Create LXC Container" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Provision a new Linux container" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">

                            <!-- Basic Info Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Basic Information" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewLxcIdTextBoxProxmox" Header="Container ID" IsReadOnly="True" PlaceholderText="Auto-assigned" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="NewLxcHostnameTextBoxProxmox" Grid.Column="1" Header="Hostname *" PlaceholderText="my-container" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="LxcNodeSelectionComboBoxProxmox" Header="Node *" PlaceholderText="Select node"
                                                  SelectionChanged="LxcNodeSelectionComboBoxProxmox_SelectionChanged"
                                                  HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="LxcStorageSelectionComboBoxProxmox" Grid.Column="1" Header="Storage *" PlaceholderText="Select storage" HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="LxcPoolSelectionComboBoxProxmox" Grid.Column="2" Header="Pool" PlaceholderText="None (optional)" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <ComboBox x:Name="LxcTemplateSelectionComboBoxProxmox" Header="OS Template *" PlaceholderText="Select template" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- Resources Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7F8;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Resources" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="NewLxcCpuNumberBoxProxmox" Header="CPU Cores *" Value="1" Minimum="1" Maximum="128" SpinButtonPlacementMode="Compact"/>
                                        <NumberBox x:Name="NewLxcMemoryNumberBoxProxmox" Grid.Column="1" Header="Memory (MB) *" Value="512" Minimum="16" SpinButtonPlacementMode="Compact"/>
                                        <NumberBox x:Name="NewLxcSwapNumberBoxProxmox" Grid.Column="2" Header="Swap (MB)" Value="512" Minimum="0" SpinButtonPlacementMode="Compact"/>
                                        <NumberBox x:Name="NewLxcDiskNumberBoxProxmox" Grid.Column="3" Header="Disk (GB) *" Value="8" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Network Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE839;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Network" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LxcBridgeTextBoxProxmox" Header="Bridge *" PlaceholderText="vmbr0" Text="vmbr0" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="LxcVlanTagTextBoxProxmox" Grid.Column="1" Header="VLAN Tag" PlaceholderText="None" HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="LxcIpConfigComboBoxProxmox" Grid.Column="2" Header="IP Mode"
                                                  SelectionChanged="LxcIpConfigComboBoxProxmox_SelectionChanged"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="DHCP"/>
                                            <ComboBoxItem Content="Static"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LxcStaticIpTextBoxProxmox" Header="IP Address/CIDR" PlaceholderText="192.168.1.100/24" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="LxcGatewayTextBoxProxmox" Grid.Column="1" Header="Gateway" PlaceholderText="192.168.1.1" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Security Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72E;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Security" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <PasswordBox x:Name="LxcPasswordBoxProxmox" Header="Root Password" PlaceholderText="Set container root password" HorizontalAlignment="Stretch"/>
                                    <CheckBox x:Name="LxcUnprivilegedCheckBoxProxmox" Content="Unprivileged Container (recommended)" IsChecked="True"/>
                                </StackPanel>
                            </Border>

                            <!-- Advanced Card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE90F;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Advanced Options" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="8">
                                            <CheckBox x:Name="LxcOnBootCheckBoxProxmox" Content="Start on boot"/>
                                            <CheckBox x:Name="LxcAutoStartCheckBoxProxmox" Content="Start after creation"/>
                                            <CheckBox x:Name="LxcProtectionCheckBoxProxmox" Content="Enable protection"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBox x:Name="LxcTagsTextBoxProxmox" Header="Tags" PlaceholderText="tag1,tag2" HorizontalAlignment="Stretch"/>
                                            <TextBox x:Name="LxcDescriptionTextBoxProxmox" Header="Description" PlaceholderText="Optional" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,20">
                                <Button x:Name="CreateLxcButtonProxmox"
                                        Content="Create Container"
                                        Click="CreateLxcButtonProxmox_Click"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        MinWidth="140"/>
                                <Button x:Name="MassCreateLxcButtonProxmox"
                                        Click="MassCreateLxcButtonProxmox_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE71D;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                        <TextBlock Text="Mass Create LXC"/>
                                    </StackPanel>
                                </Button>
                                <ProgressRing x:Name="CreateLxcProgressRing" IsActive="False" Width="20" Height="20"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Mass LXC Creation dialog -->
                <ContentDialog x:Name="MassLxcCreationDialog"
                               Title="Mass LXC Container Creation"
                               PrimaryButtonText="Create Containers"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="MassLxcCreationDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <Grid MinWidth="480">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Pivot Grid.Row="1">
                                <PivotItem Header="Basic Info">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <NumberBox x:Name="MassLxcCountNumberBox" Header="Number of containers *" Value="5" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact"/>
                                            <ComboBox x:Name="MassLxcNodeSelectionComboBox" Header="Node *" PlaceholderText="Select node" SelectionChanged="MassLxcNodeSelectionComboBox_SelectionChanged" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassLxcTemplateSelectionComboBox" Header="OS Template *" PlaceholderText="Select template" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassLxcStorageSelectionComboBox" Header="Storage *" PlaceholderText="Select storage" HorizontalAlignment="Stretch"/>
                                            <ComboBox x:Name="MassLxcPoolSelectionComboBox" Header="Pool" PlaceholderText="None (optional)" HorizontalAlignment="Stretch"/>
                                            <TextBox x:Name="MassLxcNamePrefixTextBox" Header="Hostname Prefix" PlaceholderText="ct (e.g. web → web-1, web-2)" HorizontalAlignment="Stretch"/>
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <NumberBox x:Name="MassLxcCpuCoresNumberBox" Header="CPU Cores *" Value="1" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                                <NumberBox x:Name="MassLxcMemoryMBNumberBox" Grid.Column="1" Header="Memory (MB) *" Value="512" Minimum="16" SpinButtonPlacementMode="Compact"/>
                                                <NumberBox x:Name="MassLxcSwapMBNumberBox" Grid.Column="2" Header="Swap (MB)" Value="512" Minimum="0" SpinButtonPlacementMode="Compact"/>
                                                <NumberBox x:Name="MassLxcDiskSizeGBNumberBox" Grid.Column="3" Header="Disk (GB) *" Value="8" Minimum="1" SpinButtonPlacementMode="Compact"/>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </PivotItem>
                                <PivotItem Header="Network &amp; Security">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                        <StackPanel Spacing="10" Margin="0,8,0,0">
                                            <TextBox x:Name="MassLxcBridgeTextBox" Header="Bridge *" PlaceholderText="vmbr0" Text="vmbr0" HorizontalAlignment="Stretch"/>
                                            <PasswordBox x:Name="MassLxcPasswordBox" Header="Root Password" PlaceholderText="Container root password" HorizontalAlignment="Stretch"/>
                                            <CheckBox x:Name="MassLxcUnprivilegedCheckBox" Content="Unprivileged Container" IsChecked="True"/>
                                            <CheckBox x:Name="MassLxcOnBootCheckBox" Content="Start on boot" IsChecked="True"/>
                                            <CheckBox x:Name="MassLxcAutoStartCheckBox" Content="Auto start after creation"/>
                                            <CheckBox x:Name="MassLxcProtectionCheckBox" Content="Enable Protection"/>
                                            <TextBox x:Name="MassLxcTagsTextBox" Header="Tags" PlaceholderText="tag1,tag2" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </PivotItem>
                            </Pivot>
                            <ProgressBar Grid.Row="2" x:Name="MassLxcCreationProgressBar" Visibility="Collapsed" Margin="0,12,0,0"/>
                        </Grid>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- ═══════════════════════════════════════════════════════ NETWORK CONFIG -->
                <Grid x:Name="NetworkConfigPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE839;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Network Configuration" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Manage host network interfaces" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <InfoBar x:Name="StatusInfoBar2Proxmox"
                             Grid.Row="1"
                             IsOpen="True"
                             Severity="Warning"
                             Title="Alpha Feature"
                             Message="Network interface editing is in alpha. Changes may require a server reboot to take effect."
                             Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="2">
                        <StackPanel Spacing="12">

                            <!-- Node + Interface selector card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Host Selection" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="NodeComboBox" Header="Node" PlaceholderText="Select node"
                                              SelectionChanged="NodeComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- Interface list card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE839;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Network Interfaces" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <ListView x:Name="NetworkListView"
                                              ItemsSource="{x:Bind NetworkInterfaces, Mode=OneWay}"
                                              SelectionMode="None"
                                              MinHeight="200">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="helpers:NetworkInterface">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="32" Height="32" CornerRadius="6"
                                                            Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                            VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE839;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Iface}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{x:Bind Type}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.55"/>
                                                            <TextBlock Text="|" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.3"/>
                                                            <TextBlock Text="{x:Bind Method}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.55"/>
                                                            <TextBlock Text="|" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.3"/>
                                                            <TextBlock Text="{x:Bind Address}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Button Grid.Column="3" Click="Button_Click" Tag="{Binding}"
                                                            ToolTipService.ToolTip="Edit interface"
                                                            Width="32" Height="32" Padding="0">
                                                        <FontIcon Glyph="&#xE70F;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                            <!-- IP Config card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE968;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="IP Configuration" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="NetworkInterfaceComboBox" Header="Interface" PlaceholderText="Select interface" HorizontalAlignment="Stretch"/>
                                        <ComboBox x:Name="NetworkModelComboBoxProxmox" Grid.Column="1" Header="Network Model" PlaceholderText="Select model" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="VirtIO"/>
                                            <ComboBoxItem Content="E1000"/>
                                            <ComboBoxItem Content="RTL8139"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="BridgeTextBoxProxmox" Header="Bridge" PlaceholderText="vmbr0" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="MacAddressTextBox" Grid.Column="1" Header="MAC Address" PlaceholderText="Auto-generated" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <ComboBox x:Name="IpConfigMethodComboBox" Header="IP Method" PlaceholderText="Select method" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="DHCP"/>
                                        <ComboBoxItem Content="Static"/>
                                    </ComboBox>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="IpAddressTextBox" Header="IP Address" PlaceholderText="192.168.1.100" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="SubnetMaskTextBox" Grid.Column="1" Header="Subnet Mask" PlaceholderText="255.255.255.0" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="GatewayTextBox" Header="Gateway" PlaceholderText="192.168.1.1" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="DnsServersTextBox" Grid.Column="1" Header="DNS Servers" PlaceholderText="8.8.8.8,8.8.4.4" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <TextBox x:Name="IpConfig0TextBoxProxmox" Header="Raw IP Config" PlaceholderText="ip=dhcp or ip=192.168.1.100/24,gw=192.168.1.1" IsEnabled="False" HorizontalAlignment="Stretch"/>
                                    <CheckBox x:Name="FirewallCheckBoxProxmox" Content="Enable Firewall" IsChecked="True"/>
                                    <Button x:Name="SaveButton" Content="Save Network Configuration" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ USERS & GROUPS -->
                <Grid x:Name="UsersGroups" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{ThemeResource AccentButtonBackground}">
                                <FontIcon Glyph="&#xE716;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Users &amp; Groups" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage Proxmox users and access groups" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="RefreshButton" Grid.Column="1" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Users + Groups columns -->
                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Users Card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Users header -->
                                <Border Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE77B;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Users" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                </Border>

                                <ListView x:Name="UsersListView"
                                          Grid.Row="1"
                                          Margin="0"
                                          ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="16,8"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:UserItem">
                                            <CheckBox Content="{x:Bind UserId, Mode=OneWay}"
                                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                      Checked="UserCheckBox_Checked"
                                                      Unchecked="UserCheckBox_Unchecked"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Users actions -->
                                <Border Grid.Row="2" Padding="12,10"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="AddUserButton" Click="AddUserButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8FA;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Add"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="EditUserButton" Click="EditUserButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Edit"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="DeleteUserButton" Click="DeleteUserButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Groups Card -->
                        <Border Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Groups header -->
                                <Border Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE902;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Groups" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                </Border>

                                <ListView x:Name="GroupsListView"
                                          Grid.Row="1"
                                          Margin="0"
                                          ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                                          ItemClick="GroupsListView_ItemClick"
                                          IsItemClickEnabled="True">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="16,8"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>

                                <!-- Groups actions -->
                                <Border Grid.Row="2" Padding="12,10"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="AddGroupButton" Click="AddGroupButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8FA;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Add"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="EditGroupButton" Click="EditGroupButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Edit"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="DeleteGroupButton" Click="DeleteGroupButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ SERVER STATS -->
                <Grid x:Name="ServerStatsPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{ThemeResource AccentButtonBackground}">
                                <FontIcon Glyph="&#xE9D2;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Server Statistics" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LastUpdateTextBlock" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RefreshStats" Click="RefreshStats_Click"
                                    ToolTipService.ToolTip="Refresh stats">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                            <Button x:Name="SettingsButton" ToolTipService.ToolTip="Settings">
                                <FontIcon Glyph="&#xE713;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Spacing="12" Width="200">
                                            <TextBlock Text="Refresh Interval (seconds)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                            <NumberBox x:Name="RefreshIntervalNumberBox"
                                                       Minimum="1"
                                                       Maximum="60"
                                                       SpinButtonPlacementMode="Compact"
                                                       ValueChanged="RefreshIntervalNumberBox_ValueChanged"/>
                                            <Button x:Name="SaveSettingsButton"
                                                    Content="Save"
                                                    Click="SaveSettingsButton_Click"
                                                    Style="{ThemeResource AccentButtonStyle}"
                                                    HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Rectangle Grid.Row="1" Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,16,0,16"/>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl x:Name="ServerStatsItemsControlProxmox">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="320"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="helpers:ServerStatProxmox">
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,12,12"
                                            Padding="16">
                                        <StackPanel Spacing="12">

                                            <!-- Node name + VM count -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border Width="32" Height="32" CornerRadius="6"
                                                            Background="{ThemeResource AccentButtonBackground}">
                                                        <FontIcon Glyph="&#xE8B7;" FontSize="15" FontFamily="Segoe Fluent Icons"
                                                                  Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding HostName}"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" CornerRadius="12" Padding="8,3"
                                                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE7F8;" FontSize="11" FontFamily="Segoe Fluent Icons" Opacity="0.6"/>
                                                        <TextBlock Text="{Binding VmCount}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                                   FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <!-- CPU -->
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="CPU" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding CpuUsageText}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                                <ProgressBar Value="{Binding CpuUsage}" Maximum="100" CornerRadius="2"/>
                                            </StackPanel>

                                            <!-- Memory -->
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Memory" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MemoryUsageText}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                                <ProgressBar Value="{Binding MemoryUsage}" Maximum="100" CornerRadius="2"/>
                                            </StackPanel>

                                            <!-- Storage -->
                                            <StackPanel Spacing="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Storage" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding StorageUsageText}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                                               FontWeight="SemiBold"/>
                                                </Grid>
                                                <ProgressBar Value="{Binding StorageUsage}" Maximum="100" CornerRadius="2"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ MANAGE POOLS -->
                <Grid x:Name="ManagePoolsPanel" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xEA8A;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resource Pools" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Organize VMs and control group access" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Content: list + details -->
                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Pool list card -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Pool list header with actions -->
                                <Border Padding="12,10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="AddPoolButton" Click="AddPoolButton_Click" ToolTipService.ToolTip="Create pool">
                                            <FontIcon Glyph="&#xE710;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                        </Button>
                                        <Button x:Name="RefreshPoolsButton" Click="RefreshPoolsButton_Click" ToolTipService.ToolTip="Refresh">
                                            <FontIcon Glyph="&#xE72C;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <ListView x:Name="PoolsListView"
                                          Grid.Row="1"
                                          SelectionMode="Single"
                                          SelectionChanged="PoolsListView_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="16,10"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xEA8A;" FontSize="14" FontFamily="Segoe Fluent Icons" Opacity="0.6"/>
                                                <TextBlock Text="{Binding PoolId}"
                                                           Style="{ThemeResource BodyTextBlockStyle}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!-- Pool details card -->
                        <Border x:Name="PoolDetailsPanel"
                                Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="16">

                                    <TextBox x:Name="PoolIdTextBox"
                                             Header="Pool ID"
                                             IsReadOnly="True"
                                             HorizontalAlignment="Stretch"/>

                                    <TextBox x:Name="PoolCommentTextBox"
                                             Header="Comment / Description"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="80"
                                             HorizontalAlignment="Stretch"/>

                                    <!-- VMs in pool -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE7F8;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="VMs in Pool" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        </StackPanel>
                                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <ListView x:Name="VMListView" MaxHeight="180" SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,2">
                                                            <TextBlock Text="{Binding name}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding status}"
                                                                       Foreground="{Binding status, Converter={StaticResource StatusToColorConverterProxmox}}"
                                                                       Opacity="0.8"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Border>
                                    </StackPanel>

                                    <!-- Storage in pool -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="Storage in Pool" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        </StackPanel>
                                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="6">
                                            <ListView x:Name="StorageListView" MaxHeight="120" SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="4,2">
                                                            <TextBlock Text="{Binding storage}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding type}" Opacity="0.6"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Border>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="SavePoolButton"
                                                Content="Save Changes"
                                                Click="SavePoolButton_Click"
                                                Style="{ThemeResource AccentButtonStyle}"
                                                MinWidth="120"/>
                                        <Button x:Name="DeletePoolButton"
                                                Click="DeletePoolButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Delete Pool"
                                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══ SNAPSHOTS ═══ -->
                <Grid x:Name="SnapshotsPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <Border Width="36" Height="36" CornerRadius="8" Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE81C;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Snapshots" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Manage VM and LXC snapshots" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- VM selector card -->
                    <Border Grid.Row="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SnapshotVmComboBox" Header="Select VM / Container"
                                      PlaceholderText="Choose a VM or LXC"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="SnapshotVmComboBox_SelectionChanged"/>
                            <Button Grid.Column="1" VerticalAlignment="Bottom"
                                    Click="CreateSnapshotButton_Click"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Create Snapshot"/>
                                </StackPanel>
                            </Button>
                            <ProgressRing x:Name="SnapshotProgressRing" Grid.Column="2"
                                          IsActive="False" Width="20" Height="20"
                                          VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                        </Grid>
                    </Border>

                    <!-- Snapshot list -->
                    <Border Grid.Row="2"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListView x:Name="SnapshotsListView" SelectionMode="Single" Padding="4">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="6"
                                                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE81C;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                <TextBlock Text="{Binding Description}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Date}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <!-- Snapshot actions -->
                            <Border Grid.Row="1" Padding="12,10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="RollbackSnapshotButton" Click="RollbackSnapshotButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7A7;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                            <TextBlock Text="Rollback"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="DeleteSnapshotButton" Click="DeleteSnapshotButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            <TextBlock Text="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Create Snapshot dialog -->
                <ContentDialog x:Name="CreateSnapshotDialog"
                               Title="Create Snapshot"
                               PrimaryButtonText="Create"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="CreateSnapshotDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="360">
                            <TextBox x:Name="SnapshotNameTextBox" Header="Snapshot Name *"
                                     PlaceholderText="e.g. before-upgrade"
                                     HorizontalAlignment="Stretch"/>
                            <TextBox x:Name="SnapshotDescriptionTextBox" Header="Description"
                                     PlaceholderText="Optional description"
                                     HorizontalAlignment="Stretch"/>
                            <CheckBox x:Name="SnapshotIncludeRamCheckBox"
                                      Content="Include RAM state (VM only, slower)"/>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- Clone dialog -->
                <ContentDialog x:Name="CloneDialog"
                               Title="Clone VM / Container"
                               PrimaryButtonText="Clone"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="CloneDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="400">
                            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                     Title="Clone"
                                     Message="A full clone creates a completely independent copy. A linked clone shares the base disk (faster but requires the original)."/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CloneNewIdTextBox" Header="New VM ID"
                                         PlaceholderText="Auto-assigned" HorizontalAlignment="Stretch"/>
                                <TextBox x:Name="CloneNewNameTextBox" Grid.Column="1" Header="Name *"
                                         PlaceholderText="clone-of-vm" HorizontalAlignment="Stretch"/>
                            </Grid>
                            <ComboBox x:Name="CloneTargetNodeComboBox" Header="Target Node"
                                      PlaceholderText="Same node" HorizontalAlignment="Stretch"/>
                            <ComboBox x:Name="CloneStorageComboBox" Header="Storage"
                                      PlaceholderText="Same storage" HorizontalAlignment="Stretch"/>
                            <ToggleSwitch x:Name="CloneFullToggle" Header="Clone Type"
                                         OnContent="Full Clone" OffContent="Linked Clone" IsOn="True"/>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- Migrate dialog -->
                <ContentDialog x:Name="MigrateDialog"
                               Title="Migrate VM / Container"
                               PrimaryButtonText="Migrate"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="MigrateDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="360">
                            <ComboBox x:Name="MigrateTargetNodeComboBox" Header="Target Node *"
                                      PlaceholderText="Select destination node"
                                      HorizontalAlignment="Stretch"/>
                            <ToggleSwitch x:Name="MigrateOnlineToggle" Header="Live Migration"
                                         OnContent="Online (no downtime)" OffContent="Offline" IsOn="True"/>
                            <CheckBox x:Name="MigrateWithLocalDisksCheckBox"
                                      Content="Migrate local disks (VMs only)"/>
                            <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                                     Title="Note"
                                     Message="Live migration requires shared storage or local-disk migration enabled. Ensure the target node has sufficient resources."/>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- ═══ BACKUP ═══ -->
                <Grid x:Name="BackupPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <Border Width="36" Height="36" CornerRadius="8" Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE8AD;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Backup &amp; Restore" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Create and manage vzdump backups" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls -->
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="BackupNodeComboBox" Header="Node"
                                      PlaceholderText="Select node"
                                      SelectionChanged="BackupNodeComboBox_SelectionChanged"
                                      HorizontalAlignment="Stretch"/>
                            <ComboBox x:Name="BackupStorageComboBox" Grid.Column="1" Header="Storage"
                                      PlaceholderText="All storages"
                                      SelectionChanged="BackupStorageComboBox_SelectionChanged"
                                      HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" VerticalAlignment="Bottom" Click="RefreshBackupsButton_Click">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                            <Button Grid.Column="3" VerticalAlignment="Bottom"
                                    Click="CreateBackupButton_Click"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8AD;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Create Backup"/>
                                </StackPanel>
                            </Button>
                            <ProgressRing x:Name="BackupProgressRing" Grid.Column="4"
                                          IsActive="False" Width="20" Height="20"
                                          VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                        </Grid>
                    </Border>

                    <!-- Backup list -->
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListView x:Name="BackupsListView" SelectionMode="Single" Padding="4">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="6"
                                                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE8AD;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding VolId}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Storage}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                    <TextBlock Text="|" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.3"/>
                                                    <TextBlock Text="{Binding Node}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding SizeFormatted}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" Opacity="0.7"/>
                                            <TextBlock Grid.Column="3" Text="{Binding DateFormatted}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" Opacity="0.5" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <!-- Backup actions -->
                            <Border Grid.Row="1" Padding="12,10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="RestoreBackupButton" Click="RestoreBackupButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7A7;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                            <TextBlock Text="Restore"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="DeleteBackupButton" Click="DeleteBackupButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            <TextBlock Text="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Create Backup dialog -->
                <ContentDialog x:Name="CreateBackupDialog"
                               Title="Create Backup"
                               PrimaryButtonText="Start Backup"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="CreateBackupDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="400">
                            <ComboBox x:Name="BackupVmComboBox" Header="VM / Container *"
                                      PlaceholderText="Select VM or LXC"
                                      HorizontalAlignment="Stretch"/>
                            <ComboBox x:Name="BackupTargetStorageComboBox" Header="Storage *"
                                      PlaceholderText="Select storage"
                                      HorizontalAlignment="Stretch"/>
                            <ComboBox x:Name="BackupModeComboBox" Header="Backup Mode" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="snapshot" IsSelected="True"/>
                                <ComboBoxItem Content="suspend"/>
                                <ComboBoxItem Content="stop"/>
                            </ComboBox>
                            <ComboBox x:Name="BackupCompressComboBox" Header="Compression" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="zstd" IsSelected="True"/>
                                <ComboBoxItem Content="lzo"/>
                                <ComboBoxItem Content="gzip"/>
                                <ComboBoxItem Content="0" />
                            </ComboBox>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- Restore Backup dialog -->
                <ContentDialog x:Name="RestoreBackupDialog"
                               Title="Restore Backup"
                               PrimaryButtonText="Restore"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="RestoreBackupDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="380">
                            <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                                     Title="Warning"
                                     Message="Restoring will create a new VM/LXC with a new ID. Existing VMs are not overwritten."/>
                            <TextBox x:Name="RestoreNewVmIdTextBox" Header="New VM ID"
                                     PlaceholderText="Auto-assigned" HorizontalAlignment="Stretch"/>
                            <ComboBox x:Name="RestoreStorageComboBox" Header="Target Storage *"
                                      PlaceholderText="Select storage"
                                      HorizontalAlignment="Stretch"/>
                            <TextBox x:Name="RestoreHostnameTextBox" Header="Hostname (LXC restore only)"
                                     PlaceholderText="restored-container" HorizontalAlignment="Stretch"/>
                            <CheckBox x:Name="RestoreUniqueCheckBox"
                                      Content="Generate unique MAC addresses" IsChecked="True"/>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- ═══ TASKS ═══ -->
                <Grid x:Name="TasksPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="8" Background="{ThemeResource AccentButtonBackground}">
                                <FontIcon Glyph="&#xE9D5;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Task Monitor" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                <TextBlock Text="View and manage running tasks" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <ComboBox x:Name="TaskNodeComboBox" PlaceholderText="Select node"
                                      SelectionChanged="TaskNodeComboBox_SelectionChanged"
                                      MinWidth="160"/>
                            <Button Click="RefreshTasksButton_Click">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Task list + log viewer -->
                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Task list -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListView x:Name="TasksListView" SelectionMode="Single"
                                          SelectionChanged="TasksListView_SelectionChanged"
                                          Padding="4">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                         Fill="{Binding StatusColor}"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Type}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                                    <TextBlock Text="{Binding Id}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Duration}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Opacity="0.5" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <Border Grid.Row="1" Padding="12,10"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,1,0,0">
                                    <Button x:Name="StopTaskButton" Click="StopTaskButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE71A;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            <TextBlock Text="Stop Task" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Task log -->
                        <Border Grid.Column="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Task Log" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" Padding="16,12" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="TaskLogTextBlock"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               IsTextSelectionEnabled="True"
                                               Opacity="0.85"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══ FIREWALL ═══ -->
                <Grid x:Name="FirewallPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <Border Width="36" Height="36" CornerRadius="8" Background="{ThemeResource AccentButtonBackground}">
                            <FontIcon Glyph="&#xE8B6;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                      Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Firewall Rules" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="Manage per-VM firewall rules" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- VM selector + controls -->
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FirewallVmComboBox" Header="VM"
                                      PlaceholderText="Select a VM"
                                      SelectionChanged="FirewallVmComboBox_SelectionChanged"
                                      HorizontalAlignment="Stretch"/>
                            <ToggleSwitch x:Name="FirewallEnabledToggle"
                                          Grid.Column="1"
                                          Header="Firewall"
                                          OnContent="Enabled" OffContent="Disabled"
                                          Toggled="FirewallEnabledToggle_Toggled"
                                          VerticalAlignment="Bottom"/>
                            <Button Grid.Column="2" VerticalAlignment="Bottom"
                                    Click="AddFirewallRuleButton_Click"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Add Rule"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3" VerticalAlignment="Bottom"
                                    Click="RefreshFirewallButton_Click">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Firewall rules list -->
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListView x:Name="FirewallRulesListView" SelectionMode="Single" Padding="4">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Pos}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" Opacity="0.5"/>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                    Background="{Binding ActionBrush}">
                                                <TextBlock Text="{Binding Action}" Style="{ThemeResource CaptionTextBlockStyle}"
                                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Source}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Dest}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Comment}" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Ellipse Grid.Column="5" Width="8" Height="8" VerticalAlignment="Center"
                                                     Fill="{Binding EnabledBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Border Grid.Row="1" Padding="12,10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                <Button x:Name="DeleteFirewallRuleButton" Click="DeleteFirewallRuleButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        <TextBlock Text="Delete Rule" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Add Firewall Rule dialog -->
                <ContentDialog x:Name="AddFirewallRuleDialog"
                               Title="Add Firewall Rule"
                               PrimaryButtonText="Add Rule"
                               CloseButtonText="Cancel"
                               PrimaryButtonClick="AddFirewallRuleDialog_PrimaryButtonClick">
                    <ContentDialog.Content>
                        <StackPanel Spacing="12" MinWidth="420">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="FwRuleActionComboBox" Header="Action *" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="ACCEPT" IsSelected="True"/>
                                    <ComboBoxItem Content="DROP"/>
                                    <ComboBoxItem Content="REJECT"/>
                                </ComboBox>
                                <ComboBox x:Name="FwRuleTypeComboBox" Grid.Column="1" Header="Direction *" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="in" IsSelected="True"/>
                                    <ComboBoxItem Content="out"/>
                                </ComboBox>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FwRuleSourceTextBox" Header="Source" PlaceholderText="e.g. 192.168.1.0/24" HorizontalAlignment="Stretch"/>
                                <TextBox x:Name="FwRuleDestTextBox" Grid.Column="1" Header="Destination" PlaceholderText="any" HorizontalAlignment="Stretch"/>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="FwRuleProtoComboBox" Header="Protocol" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content=""/>
                                    <ComboBoxItem Content="tcp" IsSelected="True"/>
                                    <ComboBoxItem Content="udp"/>
                                    <ComboBoxItem Content="icmp"/>
                                </ComboBox>
                                <TextBox x:Name="FwRuleDportTextBox" Grid.Column="1" Header="Dest Port" PlaceholderText="e.g. 80,443" HorizontalAlignment="Stretch"/>
                                <TextBox x:Name="FwRuleSportTextBox" Grid.Column="2" Header="Src Port" PlaceholderText="any" HorizontalAlignment="Stretch"/>
                            </Grid>
                            <TextBox x:Name="FwRuleCommentTextBox" Header="Comment" PlaceholderText="Optional note" HorizontalAlignment="Stretch"/>
                            <CheckBox x:Name="FwRuleEnabledCheckBox" Content="Enable rule" IsChecked="True"/>
                        </StackPanel>
                    </ContentDialog.Content>
                </ContentDialog>

                <!-- ═══ NODE MANAGEMENT ═══ -->
                <Grid x:Name="NodeMgmtPanelProxmox" Visibility="Collapsed" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="8" Background="{ThemeResource AccentButtonBackground}">
                                <FontIcon Glyph="&#xE8B7;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Node Management" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                <TextBlock Text="Node power, DNS, and system log" Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                        <ComboBox x:Name="NodeMgmtNodeComboBox" Grid.Column="1"
                                  PlaceholderText="Select node"
                                  SelectionChanged="NodeMgmtNodeComboBox_SelectionChanged"
                                  MinWidth="160"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="12">

                            <!-- Power control card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7E8;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Power Control" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                                             Title="Caution"
                                             Message="Rebooting or shutting down a node will affect all VMs and containers running on it."/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="NodeRebootButton" Click="NodeRebootButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72C;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                                                <TextBlock Text="Reboot Node"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="NodeShutdownButton" Click="NodeShutdownButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7E8;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                <TextBlock Text="Shutdown Node"
                                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DNS configuration card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE968;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="DNS Configuration" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                    <TextBox x:Name="NodeDnsSearchTextBox" Header="Search Domain"
                                             PlaceholderText="example.com" HorizontalAlignment="Stretch"/>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NodeDns1TextBox" Header="DNS Server 1"
                                                 PlaceholderText="8.8.8.8" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="NodeDns2TextBox" Grid.Column="1" Header="DNS Server 2"
                                                 PlaceholderText="8.8.4.4" HorizontalAlignment="Stretch"/>
                                        <TextBox x:Name="NodeDns3TextBox" Grid.Column="2" Header="DNS Server 3"
                                                 PlaceholderText="Optional" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Button Click="SaveNodeDnsButton_Click" Style="{ThemeResource AccentButtonStyle}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74E;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                            <TextBlock Text="Save DNS"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Syslog card -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE7C3;" FontSize="16" FontFamily="Segoe Fluent Icons"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="System Log" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Click="RefreshSyslogButton_Click">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" MaxHeight="300" Padding="16,12" VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="SyslogTextBlock"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   IsTextSelectionEnabled="True"
                                                   Opacity="0.8"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </NavigationView>
    </Grid>
</Window>
