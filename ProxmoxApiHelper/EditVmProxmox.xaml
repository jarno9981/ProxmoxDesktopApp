<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.EditVmProxmox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Edit VM Configuration">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="{ThemeResource AccentButtonBackground}">
                    <FontIcon Glyph="&#xE7F8;" FontSize="18"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Edit VM Configuration"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Modify hardware and system settings"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Opacity="0.6"/>
                </StackPanel>
                <ProgressRing x:Name="LoadingProgressRing"
                              Width="20" Height="20"
                              IsActive="True"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20">
            <StackPanel Spacing="8">

                <!-- EFI Warning -->
                <InfoBar x:Name="EfiWarningInfoBar"
                         Title="UEFI Notice"
                         Message="Switching to UEFI will create an EFI disk in local storage for this VM."
                         Severity="Warning"
                         IsOpen="True"
                         IsClosable="True"
                         Margin="0,0,0,8"/>

                <!-- System -->
                <controls:Expander IsExpanded="True"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Stretch">
                    <controls:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,8">
                            <FontIcon Glyph="&#xE7F8;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="System" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </controls:Expander.Header>
                    <StackPanel Spacing="12" Padding="0,8,0,16">
                        <TextBox Header="VM Name" x:Name="NameTextBox"
                                 PlaceholderText="Virtual machine name"
                                 HorizontalAlignment="Stretch"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="CPU Category" x:Name="CpuCategoryComboBox"
                                      HorizontalAlignment="Stretch"/>
                            <ComboBox Header="CPU Type" x:Name="CpuTypeComboBox"
                                      Grid.Column="1" HorizontalAlignment="Stretch"/>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <NumberBox Header="CPU Cores" x:Name="CpuCoresTextBox"
                                       SpinButtonPlacementMode="Compact"
                                       Minimum="1"/>
                            <NumberBox Header="CPU Sockets" x:Name="CpuSocketsTextBox"
                                       Grid.Column="1"
                                       SpinButtonPlacementMode="Compact"
                                       Minimum="1"/>
                            <NumberBox Header="Memory (MB)" x:Name="MemoryTextBox"
                                       Grid.Column="2"
                                       SpinButtonPlacementMode="Compact"
                                       Minimum="32"/>
                        </Grid>
                        <NumberBox Header="Balloon Memory (MB)" x:Name="BalloonTextBox"
                                   PlaceholderText="Minimum memory (0 = disabled)"
                                   SpinButtonPlacementMode="Compact"
                                   HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </controls:Expander>

                <!-- Storage -->
                <controls:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Stretch">
                    <controls:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Storage" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </controls:Expander.Header>
                    <StackPanel Spacing="12" Padding="0,8,0,16">
                        <TextBox Header="Disk Size Change" x:Name="DiskSizeTextBox"
                                 PlaceholderText="e.g. +10G to grow by 10 GB"
                                 HorizontalAlignment="Stretch"/>
                        <ComboBox Header="Storage Location" x:Name="StorageComboBox"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </controls:Expander>

                <!-- Boot Configuration -->
                <controls:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Stretch">
                    <controls:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,8">
                            <FontIcon Glyph="&#xE7E8;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Boot Configuration" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </controls:Expander.Header>
                    <StackPanel Spacing="12" Padding="0,8,0,16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="BIOS Type" x:Name="BiosTypeComboBox"
                                      HorizontalAlignment="Stretch"/>
                            <ComboBox Header="OS Type" x:Name="OsTypeComboBox"
                                      Grid.Column="1" HorizontalAlignment="Stretch"/>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="OS Version" x:Name="OsVersionComboBox"
                                      HorizontalAlignment="Stretch"/>
                            <TextBox Header="Boot Order" x:Name="BootOrderTextBox"
                                     Grid.Column="1"
                                     PlaceholderText="e.g. cdn"
                                     HorizontalAlignment="Stretch"/>
                        </Grid>
                        <ToggleSwitch Header="Start at Boot" x:Name="StartAtBootToggleSwitch"/>
                        <CheckBox x:Name="VirtioDriversCheckBox"
                                  Content="Use Virtio Drivers"
                                  Visibility="Collapsed"/>
                    </StackPanel>
                </controls:Expander>

                <!-- Network -->
                <controls:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Stretch">
                    <controls:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,8">
                            <FontIcon Glyph="&#xE839;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Network" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </controls:Expander.Header>
                    <StackPanel Spacing="12" Padding="0,8,0,16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Network Model" x:Name="NetworkModelComboBox"
                                      HorizontalAlignment="Stretch"/>
                            <TextBox Header="Bridge" x:Name="BridgeTextBox"
                                     Grid.Column="1"
                                     PlaceholderText="vmbr0"
                                     HorizontalAlignment="Stretch"/>
                        </Grid>
                        <TextBox Header="MAC Address" x:Name="MacAddressTextBox"
                                 PlaceholderText="Auto-generated if left blank"
                                 HorizontalAlignment="Stretch"/>
                        <ToggleSwitch Header="Enable Firewall" x:Name="FirewallToggleSwitch"/>
                    </StackPanel>
                </controls:Expander>

                <!-- Display -->
                <controls:Expander IsExpanded="False"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Stretch">
                    <controls:Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,8">
                            <FontIcon Glyph="&#xE7F4;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Display" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                    </controls:Expander.Header>
                    <StackPanel Spacing="12" Padding="0,8,0,16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Display Type" x:Name="DisplayTypeComboBox"
                                      HorizontalAlignment="Stretch"/>
                            <NumberBox Header="Graphics Memory (MB)" x:Name="GraphicsMemoryTextBox"
                                       Grid.Column="1"
                                       SpinButtonPlacementMode="Compact"/>
                        </Grid>
                        <ToggleSwitch Header="Enable 3D Acceleration"
                                      x:Name="Enable3DAccelerationToggleSwitch"/>
                    </StackPanel>
                </controls:Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer actions -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel"
                        x:Name="CancelButton"
                        MinWidth="80"/>
                <Button Content="Save Changes"
                        x:Name="SaveButton"
                        Style="{ThemeResource AccentButtonStyle}"
                        MinWidth="120"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
