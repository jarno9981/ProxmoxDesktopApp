<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ProxmoxApiHelper.EditGroupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ProxmoxApiHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Edit Group">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
            <Border Width="40" Height="40" CornerRadius="10"
                    Background="{ThemeResource AccentButtonBackground}">
                <FontIcon Glyph="&#xE902;" FontSize="20"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Edit Group"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Modify group properties and membership"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Opacity="0.6"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Group Info Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Group Information"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBox x:Name="GroupIdTextBox"
                                 Header="Group ID"
                                 IsReadOnly="True"
                                 HorizontalAlignment="Stretch"/>
                        <TextBox x:Name="CommentTextBox"
                                 Header="Comment"
                                 PlaceholderText="Add a description"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Members Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE716;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Group Members"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MembersStackPanel" Spacing="4"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,16,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80"/>
            <Button Content="Save Changes"
                    Click="SaveButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    MinWidth="110"/>
        </StackPanel>
    </Grid>
</Window>
